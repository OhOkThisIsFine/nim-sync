{
  "name": "nim-sync",
  "version": "1.0.9",
  "description": "OpenCode plugin to sync NVIDIA NIM models automatically",
  "main": "dist/server.mjs",
  "types": "dist/plugin/opencode-server.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin/opencode-server.d.ts",
      "import": "./dist/server.mjs"
    },
    "./server": {
      "types": "./dist/plugin/opencode-server.d.ts",
      "import": "./dist/server.mjs"
    },
    "./tui": {
      "types": "./dist/plugin/opencode-tui.d.ts",
      "import": "./dist/tui.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OhOkThisIsFine/nim-sync.git"
  },
  "homepage": "https://github.com/OhOkThisIsFine/nim-sync#readme",
  "bugs": {
    "url": "https://github.com/OhOkThisIsFine/nim-sync/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:ts": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "build": "npm run clean && npm run build:ts && npm run bundle",
    "prepack": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "release:check": "node scripts/verify-release-tag.mjs"
  },
  "keywords": [
    "opencode",
    "plugin",
    "nvidia",
    "nim"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "opencode": "^1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.6",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.25.11",
    "eslint": "^8.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.0",
    "audit-code": "^0.2.0",
    "jsonc-parser": "^3.3.1"
  }
}
