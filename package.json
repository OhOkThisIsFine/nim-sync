{
  "name": "opencode-nim-sync",
  "version": "1.0.0",
  "description": "OpenCode plugin to sync NVIDIA NIM models automatically",
  "main": "dist/nim-sync.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/nim-sync.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:ts": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "build": "npm run clean && npm run build:ts && npm run bundle",
    "prepack": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "nvidia",
    "nim"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.25.11",
    "eslint": "^8.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.0",
    "jsonc-parser": "^3.3.1"
  }
}
